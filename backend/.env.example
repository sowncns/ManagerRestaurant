NODE_ENV=development
PORT=5000

# PostgreSQL (Supabase host hoac local)
DATABASE_URL=postgresql://user:password@host:5432/postgres

# Redis
REDIS_URL=redis://localhost:6379

# JWT (tu viet)
JWT_ACCESS_SECRET=change-me
JWT_REFRESH_SECRET=change-me
JWT_ACCESS_EXPIRES=1d
JWT_REFRESH_EXPIRES=7d

# Rate limit (production luon bat)
RATE_LIMIT_ENABLED=false

CORS_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# PayOS
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=

# Mail (Nodemailer)
MAIL_USER=
MAIL_PASS=

RESERVATION_ALERT_MINUTES=30
RESERVATION_DEPOSIT_RATE=0.3

# Supabase (Realtime + Auth hybrid)
SUPABASE_URL=
SUPABASE_ANON_KEY=
# SERVICE_ROLE_KEY chi dung o backend, KHONG dua ra frontend.
SUPABASE_SERVICE_ROLE_KEY=

# Domain email ao cho tai khoan noi bo (nhan vien).
INTERNAL_AUTH_EMAIL_DOMAIN=restaurant-internal.local
